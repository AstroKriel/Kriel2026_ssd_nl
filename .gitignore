## virtual environment directory
venv/

## build artifacts and metadata
dist/
**.egg-info/

## extraneous MacOS files
.DS_Store
__pycache__/

## ignore generated dataset products by default
datasets/**

## reopen directories so git can find the tracked reproducibility inputs
!datasets/
!datasets/sims/
!datasets/sims/**/

## track reproducibility inputs and suite-level outputs
!datasets/sims/**/sim_data.json
!datasets/suite_fit_posteriors.json
!datasets/suite_scalings.json

